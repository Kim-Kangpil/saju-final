# Supabase (PostgreSQL) — Phase 0 이후 사용
# Supabase 대시보드: Project Settings → Database → Connection string → URI
# async 사용 시: postgresql+asyncpg://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql+asyncpg://...

# 기존 환경 변수 (참고)
# FRONTEND_URL=https://hsaju.com
# CORS_ORIGINS=https://hsaju.com,https://www.hsaju.com
# OPENAI_API_KEY=sk-...
# KAKAO_REST_KEY=...
# KAKAO_REDIRECT_URI=https://your-backend.onrender.com/auth/kakao/callback
# PORTONE_API_SECRET=...
# SESSION_TOKEN_SECRET=...
