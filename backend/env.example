# 카카오 로그인 (전부 설정해야 카카오 로그인 동작)
# 카카오 개발자 콘솔 https://developers.kakao.com 에서 발급
KAKAO_REST_KEY=발급받은_REST_API_키
# 카카오가 인증 후 code를 보내줄 URL → 반드시 백엔드 주소/auth/kakao/callback
# 로컬: http://localhost:8000/auth/kakao/callback
# 배포: https://your-backend.onrender.com/auth/kakao/callback
# ※ 카카오 개발자 콘솔 > 앱 > 카카오 로그인 > Redirect URI에 위 URL 등록 필수
KAKAO_REDIRECT_URI=https://your-backend.onrender.com/auth/kakao/callback
# 로그인 성공 후 이동할 프론트 주소
FRONTEND_URL=https://hsaju.com

# 기타 (선택)
# OPENAI_API_KEY=
# PORTONE_API_SECRET=
